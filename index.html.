<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>VOID HUNTER</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;600;700&display=swap');

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

html, body {
width:100%; height:100%;
background:#000;
overflow:hidden;
touch-action:none;
user-select:none;
font-family:‘Share Tech Mono’, monospace;
color:#c0c0c0;
}

#game-container {
position:relative;
width:100%;
height:100%;
display:flex;
flex-direction:column;
}

#hud {
position:absolute;
top:0; left:0; right:0;
z-index:10;
display:flex;
justify-content:space-between;
align-items:center;
padding: env(safe-area-inset-top, 10px) 14px 8px;
background: linear-gradient(to bottom, #000000cc, transparent);
pointer-events:none;
}

#title-hud {
font-family:‘Rajdhani’, sans-serif;
font-weight:700;
font-size:18px;
letter-spacing:5px;
color:#ff3030;
text-shadow:0 0 10px #ff000088;
}

.hud-stat { font-size:11px; color:#666; text-align:center; }
.hud-stat span { display:block; color:#ddd; font-size:15px; }

#health-bar {
width:80px; height:5px;
background:#1a1a1a;
border:1px solid #333;
margin-top:2px;
}
#health-fill {
height:100%;
background:linear-gradient(90deg,#ff2020,#ff6060);
box-shadow:0 0 6px #ff303088;
transition:width 0.1s;
}

canvas {
position:absolute;
top:0; left:0;
width:100%; height:100%;
display:block;
}

/* Overlay */
#overlay {
position:absolute;
inset:0;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
background:rgba(0,0,0,0.9);
z-index:20;
gap:14px;
padding:20px;
}
#overlay h1 {
font-family:‘Rajdhani’, sans-serif;
font-weight:700;
font-size:clamp(36px,10vw,60px);
letter-spacing:8px;
color:#ff2020;
text-shadow:0 0 30px #ff000099;
text-align:center;
}
#overlay .subtitle {
font-size:clamp(10px,3vw,13px);
color:#555;
letter-spacing:3px;
text-align:center;
line-height:1.8;
}
#overlay .hint {
font-size:clamp(9px,2.5vw,11px);
color:#333;
letter-spacing:2px;
text-align:center;
}
button {
margin-top:8px;
background:transparent;
border:1px solid #ff3030;
color:#ff3030;
font-family:‘Share Tech Mono’, monospace;
font-size:clamp(12px,3.5vw,15px);
letter-spacing:4px;
padding:14px 40px;
cursor:pointer;
transition:all 0.2s;
text-transform:uppercase;
-webkit-tap-highlight-color:transparent;
}
button:active {
background:#ff303020;
box-shadow:0 0 20px #ff303066;
}

/* Joystick */
#joystick-zone {
position:absolute;
bottom:0; left:0;
width:50%; height:45%;
z-index:5;
}
#joystick-base {
position:absolute;
width:110px; height:110px;
border-radius:50%;
border:2px solid #ffffff18;
background:radial-gradient(circle, #ffffff08, #00000040);
transform:translate(-50%,-50%);
pointer-events:none;
display:none;
}
#joystick-knob {
position:absolute;
width:46px; height:46px;
border-radius:50%;
background:radial-gradient(circle at 35% 35%, #6688ff99, #2244cc55);
border:2px solid #4466ffaa;
box-shadow:0 0 14px #2244ff66;
transform:translate(-50%,-50%);
pointer-events:none;
display:none;
}

/* Aim zone */
#aim-zone {
position:absolute;
bottom:0; right:0;
width:50%; height:45%;
z-index:5;
}

#wave-announce {
position:absolute;
top:40%;
left:50%;
transform:translate(-50%,-50%);
font-family:‘Rajdhani’, sans-serif;
font-weight:600;
font-size:clamp(24px,7vw,40px);
letter-spacing:8px;
color:#ff3030;
text-shadow:0 0 20px #ff0000aa;
pointer-events:none;
opacity:0;
transition:opacity 0.4s;
z-index:15;
white-space:nowrap;
}
</style>

</head>
<body>
<div id="game-container">
  <canvas id="canvas"></canvas>

  <div id="hud">
    <div id="title-hud">VOID</div>
    <div class="hud-stat">HP
      <div id="health-bar"><div id="health-fill" style="width:100%"></div></div>
    </div>
    <div class="hud-stat">SCORE<span id="score-display">0</span></div>
    <div class="hud-stat">WAVE<span id="wave-display">1</span></div>
  </div>

  <div id="joystick-zone"></div>
  <div id="aim-zone"></div>
  <div id="joystick-base"></div>
  <div id="joystick-knob"></div>

  <div id="wave-announce"></div>

  <div id="overlay">
    <h1>VOID HUNTER</h1>
    <p class="subtitle">LEFT THUMB — MOVE<br>RIGHT THUMB — AIM &amp; SHOOT</p>
    <p class="hint">AUTO-FIRE WHEN AIMING</p>
    <button id="start-btn">ENTER THE VOID</button>
  </div>
</div>

<script>
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
const overlay = document.getElementById('overlay');
const scoreDisplay = document.getElementById('score-display');
const waveDisplay = document.getElementById('wave-display');
const healthFill = document.getElementById('health-fill');
const waveAnnounce = document.getElementById('wave-announce');
const joystickZone = document.getElementById('joystick-zone');
const aimZone = document.getElementById('aim-zone');
const joystickBase = document.getElementById('joystick-base');
const joystickKnob = document.getElementById('joystick-knob');

let W, H;
function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

let gameRunning = false;
let animId;
let player, bullets, enemies, particles, score, wave, waveTimer, waveActive;
let stars = [];

// Joystick state
let joyActive = false;
let joyOrigin = {x:0,y:0};
let joyDelta = {x:0,y:0};
let joyTouchId = null;

// Aim state
let aimActive = false;
let aimPos = {x:0,y:0};
let aimTouchId = null;
let aimAngle = 0;
let autoShootTimer = 0;

// Keyboard (desktop fallback)
let keys = {};
let mouse = {x:0,y:0,down:false};

function buildStars() {
  stars = [];
  for(let i=0;i<160;i++) stars.push({x:Math.random()*2000,y:Math.random()*2000,r:Math.random()*1.3+0.2,b:Math.random()});
}
buildStars();

function initGame() {
  player = {x:W/2, y:H/2, r:14, speed:3.5, hp:100, maxHp:100, angle:0, invincible:0, trail:[]};
  bullets = []; enemies = []; particles = [];
  score = 0; wave = 1; waveTimer = 0; waveActive = false;
  autoShootTimer = 0;
  updateUI();
  spawnWave();
}

function spawnWave() {
  waveActive = true;
  const count = 4 + wave * 2;
  for(let i=0;i<count;i++) setTimeout(()=>spawnEnemy(), i*200);
  showWaveAnnounce('WAVE ' + wave);
}

function showWaveAnnounce(text) {
  waveAnnounce.textContent = text;
  waveAnnounce.style.opacity = '1';
  setTimeout(()=>{ waveAnnounce.style.opacity='0'; }, 1600);
}

function spawnEnemy() {
  if(!gameRunning) return;
  const side = Math.floor(Math.random()*4);
  let x, y;
  const pad = 30;
  if(side===0){x=Math.random()*W;y=-pad;}
  else if(side===1){x=W+pad;y=Math.random()*H;}
  else if(side===2){x=Math.random()*W;y=H+pad;}
  else{x=-pad;y=Math.random()*H;}

  const type = wave>=4?(Math.random()<0.2?'tank':(Math.random()<0.3?'fast':'basic'))
                      :(Math.random()<0.15?'fast':'basic');
  const cfg = {
    basic:{r:13,hp:2,speed:1.3+wave*0.1,color:'#cc2020',score:10},
    fast: {r:9, hp:1,speed:2.5+wave*0.18,color:'#ff7700',score:20},
    tank: {r:22,hp:6+wave,speed:0.75,   color:'#9900cc',score:50},
  }[type];
  enemies.push({x,y,type,...cfg,maxHp:cfg.hp,angle:0});
}

function spawnParticles(x,y,color,count=8){
  for(let i=0;i<count;i++){
    const a=Math.random()*Math.PI*2, sp=1.5+Math.random()*3.5;
    particles.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp,life:1,color});
  }
}

function shoot(angle) {
  bullets.push({x:player.x,y:player.y,vx:Math.cos(angle)*13,vy:Math.sin(angle)*13,r:4,life:1,player:true});
}

let enemyShootTimer = 0;
function enemyShoot(e){
  const a=Math.atan2(player.y-e.y,player.x-e.x);
  const sp=e.type==='fast'?7:4.5;
  bullets.push({x:e.x,y:e.y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp,r:5,life:1,player:false,color:e.color});
}

function updateUI(){
  scoreDisplay.textContent = score;
  waveDisplay.textContent = wave;
  healthFill.style.width = (player.hp/player.maxHp*100).toFixed(1)+'%';
}

let shootCooldown=0;

function update(){
  if(!gameRunning) return;

  // Movement: joystick or keyboard
  let dx=0, dy=0;
  if(joyActive && (joyDelta.x!==0||joyDelta.y!==0)){
    dx=joyDelta.x; dy=joyDelta.y;
  } else {
    if(keys['ArrowLeft']||keys['a']||keys['A']) dx=-1;
    if(keys['ArrowRight']||keys['d']||keys['D']) dx=1;
    if(keys['ArrowUp']||keys['w']||keys['W']) dy=-1;
    if(keys['ArrowDown']||keys['s']||keys['S']) dy=1;
    if(dx&&dy){dx*=0.707;dy*=0.707;}
  }
  player.x = Math.max(player.r, Math.min(W-player.r, player.x+dx*player.speed));
  player.y = Math.max(player.r, Math.min(H-player.r, player.y+dy*player.speed));

  // Aim angle: from aim touch or mouse
  if(aimActive){
    aimAngle = Math.atan2(aimPos.y-player.y, aimPos.x-player.x);
    player.angle = aimAngle;
  } else {
    player.angle = Math.atan2(mouse.y-player.y, mouse.x-player.x);
    aimAngle = player.angle;
  }

  // Trail
  player.trail.push({x:player.x,y:player.y,t:1});
  if(player.trail.length>14) player.trail.shift();
  player.trail.forEach(t=>t.t-=0.07);
  if(player.invincible>0) player.invincible--;

  // Auto-shoot when aim active or mouse held
  const shouldShoot = aimActive || mouse.down;
  if(shouldShoot){
    if(shootCooldown<=0){ shoot(aimAngle); shootCooldown=9; }
  }
  if(shootCooldown>0) shootCooldown--;

  // Enemy shoot
  enemyShootTimer++;
  const interval = Math.max(55-wave*3,18);
  if(enemyShootTimer>=interval){
    enemyShootTimer=0;
    enemies.forEach(e=>{ if(Math.random()<(e.type==='fast'?0.7:0.45)) enemyShoot(e); });
  }

  // Move enemies toward player
  enemies.forEach(e=>{
    const a=Math.atan2(player.y-e.y,player.x-e.x);
    e.x+=Math.cos(a)*e.speed; e.y+=Math.sin(a)*e.speed;
    e.angle=a;
  });

  // Move bullets
  bullets.forEach(b=>{
    b.x+=b.vx; b.y+=b.vy;
    if(b.x<-30||b.x>W+30||b.y<-30||b.y>H+30) b.life=0;
  });

  // Bullet-enemy
  bullets.filter(b=>b.player).forEach(b=>{
    enemies.forEach(e=>{
      if(Math.hypot(b.x-e.x,b.y-e.y)<b.r+e.r){
        b.life=0; e.hp--;
        spawnParticles(b.x,b.y,e.color,5);
        if(e.hp<=0){ spawnParticles(e.x,e.y,e.color,18); score+=e.score*wave; e.dead=true; }
      }
    });
  });

  // Bullet-player
  bullets.filter(b=>!b.player).forEach(b=>{
    if(Math.hypot(b.x-player.x,b.y-player.y)<b.r+player.r && player.invincible<=0){
      b.life=0; player.hp-=10; player.invincible=30;
      spawnParticles(player.x,player.y,'#ff3030',10);
      if(player.hp<=0){gameOver();return;}
    }
  });

  // Enemy-player contact
  enemies.forEach(e=>{
    if(Math.hypot(e.x-player.x,e.y-player.y)<e.r+player.r && player.invincible<=0){
      player.hp-=15; player.invincible=40;
      spawnParticles(player.x,player.y,'#ff3030',14);
      if(player.hp<=0){gameOver();return;}
    }
  });

  bullets=bullets.filter(b=>b.life>0);
  enemies=enemies.filter(e=>!e.dead);
  particles.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vx*=0.91;p.vy*=0.91;p.life-=0.035;});
  particles=particles.filter(p=>p.life>0);

  if(waveActive && enemies.length===0){ waveActive=false; waveTimer=140; }
  if(!waveActive && waveTimer>0){
    waveTimer--;
    if(waveTimer===0){ wave++; updateUI(); spawnWave(); }
  }
  updateUI();
}

function draw(){
  ctx.fillStyle='#04040a'; ctx.fillRect(0,0,W,H);

  // Stars
  stars.forEach(s=>{
    ctx.globalAlpha=0.25+s.b*0.45;
    ctx.fillStyle='#ffffff';
    ctx.beginPath(); ctx.arc(s.x%W,s.y%H,s.r,0,Math.PI*2); ctx.fill();
  });
  ctx.globalAlpha=1;

  // Grid
  ctx.strokeStyle='#0c0c14'; ctx.lineWidth=1;
  const gs=50;
  for(let x=0;x<W;x+=gs){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
  for(let y=0;y<H;y+=gs){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}

  // Particles
  particles.forEach(p=>{
    ctx.globalAlpha=p.life*0.85;
    ctx.fillStyle=p.color;
    ctx.beginPath(); ctx.arc(p.x,p.y,3*p.life,0,Math.PI*2); ctx.fill();
  });
  ctx.globalAlpha=1;

  // Player trail
  player.trail.forEach(t=>{
    ctx.globalAlpha=Math.max(0,t.t*0.25);
    ctx.fillStyle='#3060ff';
    ctx.beginPath(); ctx.arc(t.x,t.y,5,0,Math.PI*2); ctx.fill();
  });
  ctx.globalAlpha=1;

  // Enemy bullets
  bullets.filter(b=>!b.player).forEach(b=>{
    ctx.save();
    ctx.shadowBlur=12; ctx.shadowColor=b.color||'#ff4400';
    ctx.fillStyle=b.color||'#ff6600';
    ctx.beginPath(); ctx.arc(b.x,b.y,b.r,0,Math.PI*2); ctx.fill();
    ctx.restore();
  });

  // Player bullets
  bullets.filter(b=>b.player).forEach(b=>{
    ctx.save();
    ctx.shadowBlur=14; ctx.shadowColor='#4488ff';
    ctx.fillStyle='#88ccff';
    ctx.beginPath(); ctx.arc(b.x,b.y,b.r,0,Math.PI*2); ctx.fill();
    ctx.restore();
  });

  // Enemies
  enemies.forEach(e=>{
    ctx.save();
    ctx.translate(e.x,e.y); ctx.rotate(e.angle);
    ctx.shadowBlur=16; ctx.shadowColor=e.color;
    if(e.type==='basic'){
      ctx.fillStyle=e.color;
      ctx.beginPath(); ctx.moveTo(e.r,0); ctx.lineTo(0,e.r); ctx.lineTo(-e.r,0); ctx.lineTo(0,-e.r); ctx.closePath(); ctx.fill();
      ctx.strokeStyle='#ff808055'; ctx.lineWidth=1.5; ctx.stroke();
    } else if(e.type==='fast'){
      ctx.fillStyle=e.color;
      ctx.beginPath(); ctx.moveTo(e.r,0); ctx.lineTo(-e.r,-e.r*0.7); ctx.lineTo(-e.r,e.r*0.7); ctx.closePath(); ctx.fill();
    } else {
      ctx.fillStyle=e.color;
      ctx.beginPath();
      for(let i=0;i<6;i++){const a=(i/6)*Math.PI*2; i===0?ctx.moveTo(Math.cos(a)*e.r,Math.sin(a)*e.r):ctx.lineTo(Math.cos(a)*e.r,Math.sin(a)*e.r);}
      ctx.closePath(); ctx.fill();
      ctx.strokeStyle='#cc88ff66'; ctx.lineWidth=2; ctx.stroke();
      // HP bar
      ctx.rotate(-e.angle);
      const bw=40,bh=5;
      ctx.fillStyle='#222'; ctx.fillRect(-bw/2,e.r+5,bw,bh);
      ctx.fillStyle='#aa44ff'; ctx.fillRect(-bw/2,e.r+5,bw*(e.hp/e.maxHp),bh);
    }
    ctx.restore();
  });

  // Player
  ctx.save();
  ctx.translate(player.x,player.y); ctx.rotate(player.angle);
  if(player.invincible>0 && Math.floor(player.invincible/4)%2===0) ctx.globalAlpha=0.35;
  ctx.shadowBlur=22; ctx.shadowColor='#3366ff';
  ctx.fillStyle='#c0d0ff';
  ctx.beginPath();
  ctx.moveTo(player.r,0); ctx.lineTo(-player.r+4,-player.r*0.7); ctx.lineTo(-player.r+2,0); ctx.lineTo(-player.r+4,player.r*0.7);
  ctx.closePath(); ctx.fill();
  ctx.fillStyle='#88aaff'; ctx.beginPath(); ctx.arc(2,0,4,0,Math.PI*2); ctx.fill();
  ctx.restore();
  ctx.globalAlpha=1;

  // Aim indicator (when aiming)
  if(aimActive){
    ctx.save();
    ctx.strokeStyle='#ff303044'; ctx.lineWidth=1; ctx.setLineDash([5,5]);
    ctx.beginPath(); ctx.moveTo(player.x,player.y);
    ctx.lineTo(player.x+Math.cos(aimAngle)*120, player.y+Math.sin(aimAngle)*120); ctx.stroke();
    ctx.setLineDash([]);
    ctx.strokeStyle='#ff303077'; ctx.lineWidth=1.5;
    ctx.beginPath(); ctx.arc(aimPos.x,aimPos.y,14,0,Math.PI*2); ctx.stroke();
    ctx.restore();
  }

  // Joystick visual
  if(joyActive){
    ctx.save();
    ctx.globalAlpha=0.35;
    ctx.strokeStyle='#ffffff'; ctx.lineWidth=1.5;
    ctx.beginPath(); ctx.arc(joyOrigin.x,joyOrigin.y,55,0,Math.PI*2); ctx.stroke();
    ctx.globalAlpha=0.6;
    ctx.fillStyle='#4466ff44';
    ctx.beginPath();
    const kx=joyOrigin.x+joyDelta.x*55, ky=joyOrigin.y+joyDelta.y*55;
    ctx.arc(kx,ky,22,0,Math.PI*2); ctx.fill();
    ctx.strokeStyle='#4466ffaa'; ctx.lineWidth=2;
    ctx.beginPath(); ctx.arc(kx,ky,22,0,Math.PI*2); ctx.stroke();
    ctx.restore();
  }

  // HUD hint when not aiming (first few seconds)
  if(!aimActive && !joyActive && score===0 && wave===1){
    ctx.save();
    ctx.globalAlpha=0.2;
    ctx.strokeStyle='#ffffff'; ctx.lineWidth=1; ctx.setLineDash([3,6]);
    ctx.beginPath(); ctx.arc(W*0.25,H*0.78,40,0,Math.PI*2); ctx.stroke();
    ctx.beginPath(); ctx.arc(W*0.75,H*0.78,40,0,Math.PI*2); ctx.stroke();
    ctx.globalAlpha=0.15;
    ctx.fillStyle='#ffffff'; ctx.font='10px Share Tech Mono';
    ctx.textAlign='center';
    ctx.fillText('MOVE',W*0.25,H*0.78+4);
    ctx.fillText('AIM',W*0.75,H*0.78+4);
    ctx.setLineDash([]);
    ctx.restore();
  }
}

function loop(){
  update(); draw();
  animId=requestAnimationFrame(loop);
}

function gameOver(){
  gameRunning=false;
  cancelAnimationFrame(animId);
  joyActive=false; aimActive=false;
  overlay.style.display='flex';
  overlay.innerHTML=`
    <h1 style="font-size:clamp(28px,8vw,46px)">VOID CLAIMED YOU</h1>
    <p class="subtitle" style="color:#555;letter-spacing:3px">SCORE: <span style="color:#ff3030;font-size:clamp(20px,5vw,26px)">${score}</span></p>
    <p class="hint" style="color:#333">WAVE ${wave} REACHED</p>
    <button id="start-btn">TRY AGAIN</button>
  `;
  document.getElementById('start-btn').addEventListener('click',startGame);
}

function startGame(){
  overlay.style.display='none';
  gameRunning=true;
  initGame(); loop();
}

// ---- Touch Controls ----
joystickZone.addEventListener('touchstart', e=>{
  e.preventDefault();
  const t=e.changedTouches[0];
  joyTouchId=t.identifier;
  const r=canvas.getBoundingClientRect();
  joyOrigin={x:t.clientX-r.left, y:t.clientY-r.top};
  joyDelta={x:0,y:0};
  joyActive=true;
},{passive:false});

joystickZone.addEventListener('touchmove', e=>{
  e.preventDefault();
  for(const t of e.changedTouches){
    if(t.identifier===joyTouchId){
      const r=canvas.getBoundingClientRect();
      const dx=(t.clientX-r.left)-joyOrigin.x;
      const dy=(t.clientY-r.top)-joyOrigin.y;
      const dist=Math.hypot(dx,dy);
      const max=55;
      if(dist>0){ joyDelta={x:dx/Math.max(dist,max)*Math.min(dist/max,1), y:dy/Math.max(dist,max)*Math.min(dist/max,1)}; }
      else { joyDelta={x:0,y:0}; }
    }
  }
},{passive:false});

joystickZone.addEventListener('touchend', e=>{
  e.preventDefault();
  for(const t of e.changedTouches){
    if(t.identifier===joyTouchId){ joyActive=false; joyDelta={x:0,y:0}; joyTouchId=null; }
  }
},{passive:false});

aimZone.addEventListener('touchstart', e=>{
  e.preventDefault();
  const t=e.changedTouches[0];
  aimTouchId=t.identifier;
  const r=canvas.getBoundingClientRect();
  aimPos={x:t.clientX-r.left, y:t.clientY-r.top};
  aimActive=true;
  shootCooldown=0;
},{passive:false});

aimZone.addEventListener('touchmove', e=>{
  e.preventDefault();
  for(const t of e.changedTouches){
    if(t.identifier===aimTouchId){
      const r=canvas.getBoundingClientRect();
      aimPos={x:t.clientX-r.left, y:t.clientY-r.top};
    }
  }
},{passive:false});

aimZone.addEventListener('touchend', e=>{
  e.preventDefault();
  for(const t of e.changedTouches){
    if(t.identifier===aimTouchId){ aimActive=false; aimTouchId=null; }
  }
},{passive:false});

// Desktop fallback
window.addEventListener('keydown',e=>{keys[e.key]=true;});
window.addEventListener('keyup',e=>{keys[e.key]=false;});
canvas.addEventListener('mousemove',e=>{
  const r=canvas.getBoundingClientRect();
  mouse.x=e.clientX-r.left; mouse.y=e.clientY-r.top;
});
canvas.addEventListener('mousedown',e=>{mouse.down=true;});
canvas.addEventListener('mouseup',e=>{mouse.down=false;});
canvas.addEventListener('contextmenu',e=>e.preventDefault());

document.getElementById('start-btn').addEventListener('click',startGame);
</script>

